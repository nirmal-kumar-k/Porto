# ─────────────────────────────────────────────────────────────────────────────
# Environment Variables — copy this file to .env.local for local development
# Set these as Environment Variables in the Vercel dashboard for production
# ─────────────────────────────────────────────────────────────────────────────

# Get your API key at https://resend.com → API Keys
RESEND_API_KEY=re_your_api_key_here

# The email address that contact form messages will be delivered to
CONTACT_TO_EMAIL=your@email.com
